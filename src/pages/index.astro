---
import HeroSection from '../components/HeroSection';
import ParallaxImage from '../components/ParallaxImage';
import PinnedSection from '../components/PinnedSection';
import SmoothScroll from '../components/SmoothScroll';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Jogjakarsa Storytelling Starter"
	description="An Astro, React, TailwindCSS, GSAP, and Lenis starter for cinematic scroll-driven storytelling."
>
	<SmoothScroll client:load />

	<main class="relative isolate">
		<HeroSection client:load />
		<PinnedSection client:load />
		<ParallaxImage client:load />

		<section class="relative overflow-clip border-t border-white/10 bg-ink px-6 py-24 md:px-10 lg:px-16 lg:py-32">
			<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,.9fr)] lg:items-end">
				<div class="space-y-6">
					<p class="eyebrow">Starter Notes</p>
					<h2 class="max-w-3xl font-display text-4xl leading-[0.92] tracking-[-0.05em] text-mist sm:text-5xl lg:text-6xl">
						Built for immersive sections, not one-off demos.
					</h2>
					<p class="max-w-2xl text-base text-mist/72 md:text-lg">
						The page stays Astro-first while each high-motion beat hydrates as an isolated React island. Swap the copy,
						gradient scenes, or card data without rewriting the scroll system.
					</p>
				</div>

				<div class="glass-panel story-grid relative overflow-hidden rounded-[2rem] p-8 md:p-10">
					<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(244,193,122,0.16),transparent_44%),radial-gradient(circle_at_bottom_right,rgba(145,183,255,0.14),transparent_38%)]"></div>
					<div class="relative grid gap-6 md:grid-cols-2">
						<div>
							<p class="text-sm uppercase tracking-[0.24em] text-mist/48">Includes</p>
							<ul class="mt-4 space-y-3 text-sm text-mist/72">
								<li>Astro layout shell with React islands</li>
								<li>Tailwind theme tokens and atmospheric globals</li>
								<li>GSAP helpers, pinned timeline, and parallax scene</li>
							</ul>
						</div>
						<div>
							<p class="text-sm uppercase tracking-[0.24em] text-mist/48">Next</p>
							<ul class="mt-4 space-y-3 text-sm text-mist/72">
								<li>Replace placeholder gradients with project imagery or video</li>
								<li>Move story beats into a content source when the narrative grows</li>
								<li>Add route transitions or richer scene runtimes if needed</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
