---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNavbar from '../components/SiteNavbar';
import SiteFooter from '../components/SiteFooter';
import SmoothScroll from '../components/SmoothScroll';
import BudayaHeroSection from '../components/budaya/BudayaHeroSection';
import BudayaPillarsSection from '../components/budaya/BudayaPillarsSection';
---

<BaseLayout
	title="Budaya - jogjakarsa.id"
	description="Eksplorasi 7 pilar kebudayaan yang mengakar di Yogyakarta."
>
	<SmoothScroll client:load />
	<SiteNavbar client:load />

	<main class="relative isolate">
		<BudayaHeroSection client:load />
		<BudayaPillarsSection client:load />
		<SiteFooter client:load />
	</main>
</BaseLayout>
