---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Jogjakarsa Storytelling Starter',
	description = 'Astro starter for immersive scroll storytelling with React islands, TailwindCSS, GSAP, and Lenis.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-ink text-mist">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#08111f" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-ink text-mist antialiased selection:bg-sun/30 selection:text-ink">
		<div aria-hidden="true" class="story-grain pointer-events-none fixed inset-0 z-[1]"></div>
		<div aria-hidden="true" class="pointer-events-none fixed inset-x-0 top-0 z-[1] h-40 bg-[linear-gradient(180deg,rgba(8,17,31,0.72),transparent)]"></div>
		<slot />
	</body>
</html>